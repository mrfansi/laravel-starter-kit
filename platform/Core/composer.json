{
    "name": "platform/core",
    "description": "Core module for Laravel Starter Kit",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Platform\\Core\\": "src/"
        }
    },
    "require": {
        "php": "^8.2 || ^8.3 || ^8.4"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Platform\\Core\\Providers\\CoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
