APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX=
HORIZON_ALLOWED_DOMAINS="@example.com,@example.co.id"

TELESCOPE_ENABLED=true
TELESCOPE_DOMAIN=
TELESCOPE_PATH=telescope
TELESCOPE_DRIVER=database
TELESCOPE_QUEUE_CONNECTION=
TELESCOPE_QUEUE=
TELESCOPE_QUEUE_DELAY=10
TELESCOPE_BATCH_WATCHER=true
TELESCOPE_CACHE_WATCHER=true
TELESCOPE_CLIENT_REQUEST_WATCHER=true
TELESCOPE_COMMAND_WATCHER=true
TELESCOPE_DUMP_WATCHER=true
TELESCOPE_DUMP_WATCHER_ALWAYS=false
TELESCOPE_EVENT_WATCHER=true
TELESCOPE_EXCEPTION_WATCHER=true
TELESCOPE_GATE_WATCHER=true
TELESCOPE_JOB_WATCHER=true
TELESCOPE_LOG_WATCHER=true
TELESCOPE_MAIL_WATCHER=true
TELESCOPE_MODEL_WATCHER=true
TELESCOPE_NOTIFICATION_WATCHER=true
TELESCOPE_QUERY_WATCHER=true
TELESCOPE_REDIS_WATCHER=true
TELESCOPE_REQUEST_WATCHER=true
TELESCOPE_RESPONSE_SIZE_LIMIT=64
TELESCOPE_SCHEDULE_WATCHER=true
TELESCOPE_VIEW_WATCHER=true
TELESCOPE_ALLOWED_DOMAINS="@example.com,@example.co.id"

PULSE_DOMAIN=
PULSE_PATH=pulse
PULSE_ENABLED=true
PULSE_STORAGE_DRIVER=database
PULSE_STORAGE_KEEP="7 days"
PULSE_DB_CONNECTION=
PULSE_INGEST_DRIVER=storage
PULSE_INGEST_BUFFER=5_000
PULSE_INGEST_KEEP="7 days"
PULSE_REDIS_CONNECTION=
PULSE_CACHE_DRIVER=
PULSE_CACHE_INTERACTIONS_ENABLED=true
PULSE_CACHE_INTERACTIONS_SAMPLE_RATE=1
PULSE_EXCEPTIONS_ENABLED=true
PULSE_EXCEPTIONS_SAMPLE_RATE=1
PULSE_EXCEPTIONS_LOCATION=true
PULSE_QUEUES_ENABLED=true
PULSE_QUEUES_SAMPLE_RATE=1
PULSE_SERVER_NAME="${APP_NAME}"
PULSE_SERVER_DIRECTORIES=/
PULSE_SLOW_JOBS_ENABLED=true
PULSE_SLOW_JOBS_SAMPLE_RATE=1
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_ENABLED=true
PULSE_SLOW_OUTGOING_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=1000
PULSE_SLOW_QUERIES_ENABLED=true
PULSE_SLOW_QUERIES_SAMPLE_RATE=1
PULSE_SLOW_QUERIES_THRESHOLD=1000
PULSE_SLOW_QUERIES_LOCATION=true
PULSE_SLOW_QUERIES_MAX_QUERY_LENGTH=
PULSE_SLOW_REQUESTS_ENABLED=true
PULSE_SLOW_REQUESTS_SAMPLE_RATE=1
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_USER_JOBS_ENABLED=true
PULSE_USER_JOBS_SAMPLE_RATE=1
PULSE_USER_REQUESTS_ENABLED=true
PULSE_USER_REQUESTS_SAMPLE_RATE=1
PULSE_ALLOWED_DOMAINS="@example.com,@example.co.id"

